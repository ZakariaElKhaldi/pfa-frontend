# ============================================================
# Frontend (Vite) environment — copy to frontend/.env and edit
# ============================================================
# Vite only exposes variables prefixed with VITE_ to the client bundle.
# Reference: https://vite.dev/guide/env-and-mode

# Backend REST API base URL
VITE_API_URL=http://localhost:8000

# Backend WebSocket URL (for live signals / alerts)
VITE_WS_URL=ws://localhost:8000
